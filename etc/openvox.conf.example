# =============================================================================
# ovinstall Configuration
# =============================================================================
# Copy this file to /etc/openvox/openvox.conf and modify as needed.
#
# Format:  key = value   (one per line)
# Lines starting with '#' are comments. Blank lines are ignored.
#
# Tip: Use --non-interactive if all required values are provided here
#      so the installer won't prompt for anything.
# =============================================================================

# --- General Settings --------------------------------------------------------

# Installation mode: agent, server, complete
#   agent    — OpenVox Agent only (connects to an existing server)
#   server   — Agent + Puppet Server + PuppetDB + r10k
#   complete — All components including OpenBolt + OpenVox-GUI
# Default: complete
# install_mode = complete

# Run in non-interactive mode (skip prompts)
# Default: false
# non_interactive = false

# --- Network / Server --------------------------------------------------------

# Server hostname (FQDN) — REQUIRED for server installations
# server_hostname = openvox.example.com

# --- r10k (Server Only) -----------------------------------------------------

# Git remote URL for control repository — REQUIRED when installing r10k
# r10k clones this repo and creates Puppet environments from its branches.
#   SSH:   git@github.com:yourorg/control-repo.git
#   HTTPS: https://github.com/yourorg/control-repo.git
# r10k_remote = git@github.com:yourorg/control-repo.git

# --- OpenVox-GUI -------------------------------------------------------------

# Port for the OpenVox-GUI web interface
# Default: 4567
# gui_port = 4567

# Git URL to the OpenVox-GUI repository (rarely needs to change)
# gui_repo_url = https://github.com/cvquesty/openvox-gui.git

# --- Agent Settings ----------------------------------------------------------

# Agent certificate name (use 'auto' to let Puppet use the hostname)
# Default: auto
# certname = auto

# Agent run interval (examples: 30m, 1h, 2h)
# Default: 30m
# runinterval = 30m

# --- Server / JVM Settings (Server Only) ------------------------------------

# JVM heap memory for PuppetServer (-Xmx / -Xms)
# Default: 2g
# jvm_memory = 2g

# --- PuppetDB ----------------------------------------------------------------

# Database backend: internal (local PostgreSQL) or external
# Default: internal
# puppetdb_database = internal

# Password for the PuppetDB PostgreSQL user
# Default: changeme  (CHANGE THIS in production!)
# puppetdb_password = changeme

# External database connection (only used when puppetdb_database = external)
# puppetdb_db_host = localhost
# puppetdb_db_port = 5432
# puppetdb_db_name = puppetdb
# puppetdb_db_user = puppetdb

# --- Security ----------------------------------------------------------------

# Configure firewall rules for installed components (firewalld)
# Default: false
# firewall = false

# SELinux mode (RHEL only): enforcing, permissive, disabled
# Default: permissive
# selinux = permissive

# --- Client Platform Support -------------------------------------------------

# Enable download caching for fleet deployments
# When enabled, packages are cached locally for agent bootstraps
# Default: false
# download_cache_enabled = false
# download_cache_dir = /var/cache/ovinstall
# download_cache_max_age_days = 7

# --- Modularity (Future Growth) ----------------------------------------------

# Server role: all-in-one, ca-only, compile-master
# all-in-one: Full server (CA + catalog compilation)
# ca-only: Only handle certificate operations (no compilation)
# compile-master: Catalog compilation only (points to external CA)
# Default: all-in-one
# server_role = all-in-one

# Catalog compiler hosts (comma-separated, for future use)
# compile_masters = puppet-compile1.example.com,puppet-compile2.example.com

# --- Logging -----------------------------------------------------------------

# Log level: debug, info, warning, error
# Default: info
# log_level = info

# --- Finalization ------------------------------------------------------------

# Run puppet agent -t after installation
# Default: true
# run_final_agent = true

# Environments to configure (comma-separated)
# Default: production
# environments = production,development,staging
