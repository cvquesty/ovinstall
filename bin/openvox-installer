}

# =============================================================================
# SECTION: Dry Run Output
# =============================================================================
# Display what would be installed in dry-run mode.

dry_run() {
    log_info "Components to be installed:"
    
    # Show each component that will be installed
    [[ "$INSTALL_AGENT" == "true" ]] && log_info "  - OpenVox Agent"
    [[ "$INSTALL_SERVER" == "true" ]] && log_info "  - OpenVox Server (Puppet Server)"
    [[ "$INSTALL_R10K" == "true" ]] && log_info "  - r10k (Puppet code deployment)"
    [[ "$INSTALL_GUI" == "true" ]] && log_info "  - OpenVox-GUI"
    
    # Show configuration that will be used
    if [[ -n "$server_hostname" ]]; then
        log_info "  Server hostname: $server_hostname"
    fi
    if [[ -n "$r10k_remote" ]]; then
        log_info "  Control repo: $r10k_remote"
    fi
    
    return 0
}

# =============================================================================
# SECTION: Installation Summary
# =============================================================================
# Display post-installation summary and next steps.

print_summary() {
    cat << EOF

    ========================================
    Installation Summary
    ========================================

    OpenVox installation completed successfully!

    Next steps:
    1. Review /var/log/openvox/install.log for details
    2. Configure your Puppetfile for r10k
    3. Run initial Puppet agent run:
       puppet agent -t

EOF

    # Add server-specific instructions
    if [[ "$INSTALL_SERVER" == "true" ]]; then
        cat << EOF

    Puppet Server:
    - Server is running on port 8140
    - Sign certificates: puppetserver ca sign --all

EOF
    fi

    # Add GUI-specific instructions
    if [[ "$INSTALL_GUI" == "true" ]]; then
        cat << EOF

    OpenVox-GUI:
    - URL: https://${server_hostname:-localhost}:${gui_port}
    - Credentials: Check /opt/openvox-gui/config/.credentials

EOF
    fi
}

# =============================================================================
# SECTION: Main Execution
# =============================================================================
# Main entry point for the installer.
# Orchestrates all phases of the installation process.

main() {
    # Step 1: Parse command-line arguments
    # This sets initial flags based on CLI input
    parse_args "$@"
    
    # Step 2: Display banner
    print_banner
    
    # Step 3: Check for root privileges
    # Most installation steps require root access
    if [[ $EUID -ne 0 ]]; then
        log_fatal "This script must be run as root (use sudo)"
    fi
    
    # Step 4: Display startup information
    log_info "Starting OpenVox installation..."
    log_info "Config file: $CONFIG_FILE"
    
    # Step 5: Run preflight checks
    # Validates OS support, disk space, network connectivity
    if [[ "$SKIP_PREFLIGHT" != "true" ]]; then
        run_preflight
    else
        log_warn "Skipping preflight checks (--skip-preflight)"
    fi
    
    # Step 6: Load configuration from file if it exists
    load_config "$CONFIG_FILE"
    
    # Step 7: Set install mode based on flags
    # This determines which components to install
    set_install_mode
    
    # Step 8: Interactive prompts (if not non-interactive)
    # Prompts for required values like server_hostname, r10k_remote
    prompt_for_config
    
    # Step 9: Setup logging to file
    setup_logging
    
    # Step 10: Handle dry-run mode
    if [[ "$DRY_RUN" == "true" ]]; then
        log_warn "DRY RUN MODE - No changes will be made"
        dry_run
        print_summary
        exit 0
    fi
    
    # Step 11: Execute installation phases
    
    # Phase 1: Setup repository
    # Configures package repositories (yum.voxpupuli.org or apt.voxpupuli.org)
    phase_setup_repo
    
    # Phase 2: Install components
    # Installs selected components based on flags
    phase_install_components
    
    # Phase 3: Post-install configuration
    # Configures installed components
    phase_post_install
    
    # Phase 4: Verify installation
    # Checks that installed components are running
    phase_verify
    
    # Step 12: Display completion message
    log_info "Installation complete!"
    print_summary
    
    exit 0
}

# =============================================================================
# SECTION: Script Entry Point
# =============================================================================
# Execute main function with all passed arguments.
# The "|| exit $?" ensures proper exit code propagation.

main "$@" && exit 0 || exit 1
