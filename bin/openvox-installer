#!/bin/bash
#
# =============================================================================
# OpenVox Installer - Interactive or non-interactive installer for OpenVox stack
# =============================================================================
# Automated installer for the OpenVox stack (Puppet + components).
#
# Usage:
#   Interactive mode (prompts for all required values):
#     sudo ./bin/openvox-installer
#
#   Non-interactive mode (uses CLI flags or config file):
#     sudo ./bin/openvox-installer --mode complete --non-interactive
#     sudo ./bin/openvox-installer --config /etc/openvox/openvox.conf
#     sudo ./bin/openvox-installer --agent
#
# Run with --help for full option list.
# =============================================================================

# Exit on error, undefined variables, and pipe failures
set -euo pipefail

# =============================================================================
# SECTION: Script Initialization
# =============================================================================
# Resolve the project root (parent of the bin/ directory this script lives in).
# Works regardless of working directory or symlinks.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Project subdirectory containing library scripts
LIB_DIR="${SCRIPT_DIR}/lib"

# Default configuration file location (overridden with --config)
CONFIG_FILE="/etc/openvox/openvox.conf"

# =============================================================================
# SECTION: Source Library Functions
# =============================================================================
# Load functions.sh first (provides logging, OS detection, etc.)
# then load all component installer scripts.

source "${LIB_DIR}/functions.sh"

for lib in "${LIB_DIR}"/*.sh; do
    if [[ -f "$lib" && "$lib" != "${LIB_DIR}/functions.sh" ]]; then
        # shellcheck source=/dev/null
        source "$lib"
    fi
done

# =============================================================================
# SECTION: Global Variables and Defaults
# =============================================================================
# Initialize ALL global variables with safe defaults.
# These can be overridden by CLI arguments, config file, or interactive prompts.

# Component flags (boolean strings: "true" / "false")
INSTALL_AGENT=false        # OpenVox Agent (openvox-agent package)
INSTALL_SERVER=false       # Puppet Server (includes PuppetDB)
INSTALL_GUI=false          # OpenVox-GUI (Python web interface)
INSTALL_R10K=false         # r10k (server only) — control repo deployer
INSTALL_OPENBOLT=false     # OpenBolt — agentless orchestration

# Behavior flags
DRY_RUN=false              # Show what would be installed without executing
FORCE=false                # Reinstall even if already installed
SKIP_PREFLIGHT=false       # Skip preflight checks
NONINTERACTIVE=false       # Don't prompt for user input
VERBOSE=false              # Verbose output (enables bash debug mode)

# Logging
LOG_LEVEL="info"           # debug, info, warning, error

# Installation mode (used with --mode flag)
INSTALL_MODE="complete"    # agent | server | complete

# Configuration values (populated from config file or interactive prompts)
server_hostname=""         # FQDN of the Puppet server (REQUIRED for server)
r10k_remote=""             # Git URL to control repo (REQUIRED for r10k)
gui_port="4567"            # Port for OpenVox-GUI web interface

# Tracking flag: did the user explicitly pick components via CLI flags?
# If true, set_install_mode() skips mode-based defaults.
EXPLICIT_COMPONENTS=false

# =============================================================================
# SECTION: Usage / Help
# =============================================================================

usage() {
    local exit_code="${1:-0}"
    cat << EOF
OpenVox Installer - Automated OpenVox Stack Installation

Usage: $0 [OPTIONS]

OPTIONS:
    -c, --config FILE       Configuration file (default: /etc/openvox/openvox.conf)
    -m, --mode MODE         Installation mode: agent|server|complete
                            - agent:    OpenVox Agent only
                            - server:   Agent + Puppet Server + PuppetDB + r10k
                            - complete: All components including OpenBolt + GUI
    --agent                 Install only the OpenVox Agent (implies --non-interactive)
    --server                Install OpenVox Server (agent + PuppetDB + r10k)
    --gui                   Install OpenVox-GUI
    --openbolt              Install OpenBolt (agentless orchestration)
    --non-interactive       Run without prompting (for scripted installs)
    -d, --dry-run           Show what would be done without executing
    -f, --force             Force installation even if already installed
    -s, --skip-preflight    Skip preflight checks
    -v, --verbose           Verbose output
    -h, --help              Show this help message

EXAMPLES:
    # Interactive installation (prompts for required values):
    sudo $0

    # Non-interactive with all defaults:
    sudo $0 --mode complete --non-interactive

    # Agent only:
    sudo $0 --agent

    # Server with r10k (requires r10k_remote in config or prompt):
    sudo $0 --server

    # With custom configuration file:
    sudo $0 --config /path/to/openvox.conf

    # Preview what would be installed:
    sudo $0 --dry-run

CONFIGURATION:
    Configuration can be provided via:
    1. Interactive prompts (default behavior)
    2. Command-line flags (--agent, --server, etc.)
    3. Configuration file (--config /path/to/openvox.conf)

    See etc/openvox.conf.example for all configuration options.

EOF
    exit "$exit_code"
}

# =============================================================================
# SECTION: Command-Line Argument Parsing
# =============================================================================

parse_args() {
    INSTALL_AGENT=false
    INSTALL_SERVER=false
    INSTALL_R10K=false
    INSTALL_GUI=false
    INSTALL_OPENBOLT=false
    EXPLICIT_COMPONENTS=false

    while [[ $# -gt 0 ]]; do
        case $1 in
            -c|--config)
                [[ $# -lt 2 ]] && log_fatal "--config requires a file path argument"
                CONFIG_FILE="$2"
                shift 2
                ;;

            -m|--mode)
                [[ $# -lt 2 ]] && log_fatal "--mode requires an argument (agent|server|complete)"
                INSTALL_MODE="$2"
                shift 2
                ;;

            --agent)
                INSTALL_AGENT=true
                INSTALL_SERVER=false
                INSTALL_R10K=false
                INSTALL_GUI=false
                INSTALL_OPENBOLT=false
                EXPLICIT_COMPONENTS=true
                NONINTERACTIVE=true
                shift
                ;;

            --server)
                INSTALL_AGENT=true
                INSTALL_SERVER=true
                INSTALL_R10K=true
                EXPLICIT_COMPONENTS=true
                shift
                ;;

            --gui)
                INSTALL_GUI=true
                EXPLICIT_COMPONENTS=true
                shift
                ;;

            --openbolt)
                INSTALL_OPENBOLT=true
                EXPLICIT_COMPONENTS=true
                shift
                ;;

            --non-interactive)
                NONINTERACTIVE=true
                shift
                ;;

            -d|--dry-run)
                DRY_RUN=true
                shift
                ;;

            -f|--force)
                FORCE=true
                shift
                ;;

            -s|--skip-preflight)
                SKIP_PREFLIGHT=true
                shift
                ;;

            -v|--verbose)
                VERBOSE=true
                LOG_LEVEL="debug"
                set -x
                shift
                ;;

            -h|--help)
                usage 0
                ;;

            *)
                log_error "Unknown option: $1"
                usage 1
                ;;
        esac
    done
}

# =============================================================================
# SECTION: Interactive Prompts
# =============================================================================
# Prompt user for required configuration values when running interactively.

prompt_for_config() {
    if [[ "$NONINTERACTIVE" == "true" ]]; then
        return 0
    fi

    echo ""
    echo "=========================================="
    echo "  OpenVox Configuration"
    echo "=========================================="
    echo ""

    # Server hostname — required for anything beyond agent-only
    if [[ "$INSTALL_SERVER" == "true" || "$INSTALL_MODE" != "agent" ]]; then
        if [[ -z "$server_hostname" ]]; then
            read -rp "Enter server hostname (FQDN): " server_hostname
            if [[ -z "$server_hostname" ]]; then
                log_fatal "Server hostname is required"
            fi
        fi
    fi

    # r10k control repo URL — required when installing r10k
    if [[ "$INSTALL_R10K" == "true" ]]; then
        if [[ -z "$r10k_remote" ]]; then
            echo ""
            echo "r10k requires a Git control repository URL."
            echo "  SSH example:   git@github.com:yourorg/control-repo.git"
            echo "  HTTPS example: https://github.com/yourorg/control-repo.git"
            echo ""
            read -rp "Enter control repo Git URL: " r10k_remote
            if [[ -z "$r10k_remote" ]]; then
                log_fatal "Control repo URL is required for r10k"
            fi
        fi
    fi

    # GUI port — optional
    if [[ "$INSTALL_GUI" == "true" ]]; then
        read -rp "Enter GUI port [default: $gui_port]: " input_port
        if [[ -n "${input_port:-}" ]]; then
            gui_port="$input_port"
        fi
    fi

    echo ""
    echo "Configuration complete."
    echo ""
}

# =============================================================================
# SECTION: Install Mode Configuration
# =============================================================================
# Map the --mode value to component flags (unless the user already set
# explicit flags like --agent, --server, --gui, etc.)

set_install_mode() {
    if [[ "$EXPLICIT_COMPONENTS" == "true" ]]; then
        log_info "Using explicit component selection"
        return 0
    fi

    case "$INSTALL_MODE" in
        agent)
            INSTALL_AGENT=true
            INSTALL_SERVER=false
            INSTALL_R10K=false
            INSTALL_GUI=false
            INSTALL_OPENBOLT=false
            ;;
        server)
            INSTALL_AGENT=true
            INSTALL_SERVER=true
            INSTALL_R10K=true
            INSTALL_GUI=false
            INSTALL_OPENBOLT=false
            ;;
        complete)
            INSTALL_AGENT=true
            INSTALL_SERVER=true
            INSTALL_R10K=true
            INSTALL_GUI=true
            INSTALL_OPENBOLT=true
            ;;
        *)
            log_fatal "Unknown install mode: $INSTALL_MODE (valid: agent, server, complete)"
            ;;
    esac

    log_info "Installation mode: $INSTALL_MODE"
}

# =============================================================================
# SECTION: Banner Display
# =============================================================================

print_banner() {
    cat << 'EOF'

     ___  ____  _____ _   ___     ____  __  __
    / _ \|  _ \| ____| \ | \ \   / / _ \ \/ /
   | | | | |_) |  _| |  \| |\ \ / / | | \  /
   | |_| |  __/| |___| |\  | \ V /| |_| /  \
    \___/|_|   |_____|_| \_|  \_/  \___/_/\_\

    OpenVox Automated Installer v0.3.0
    ====================================

EOF
}

# =============================================================================
# SECTION: Dry Run Output
# =============================================================================

dry_run() {
    log_info "Components to be installed:"

    [[ "$INSTALL_AGENT"    == "true" ]] && log_info "  - OpenVox Agent"
    [[ "$INSTALL_SERVER"   == "true" ]] && log_info "  - OpenVox Server (Puppet Server + PuppetDB)"
    [[ "$INSTALL_R10K"     == "true" ]] && log_info "  - r10k (Puppet code deployment)"
    [[ "$INSTALL_OPENBOLT" == "true" ]] && log_info "  - OpenBolt (agentless orchestration)"
    [[ "$INSTALL_GUI"      == "true" ]] && log_info "  - OpenVox-GUI"

    [[ -n "$server_hostname" ]] && log_info "  Server hostname: $server_hostname"
    [[ -n "$r10k_remote" ]]     && log_info "  Control repo:    $r10k_remote"

    return 0
}

# =============================================================================
# SECTION: Installation Summary
# =============================================================================

print_summary() {
    cat << EOF

    ========================================
    Installation Summary
    ========================================

    OpenVox installation completed successfully!

    Next steps:
    1. Review /var/log/openvox/install.log for details
    2. Configure your Puppetfile for r10k
    3. Run initial Puppet agent run:
       puppet agent -t

EOF

    if [[ "$INSTALL_SERVER" == "true" ]]; then
        cat << EOF
    Puppet Server:
    - Server is running on port 8140
    - Sign certificates: puppetserver ca sign --all

EOF
    fi

    if [[ "$INSTALL_GUI" == "true" ]]; then
        cat << EOF
    OpenVox-GUI:
    - URL: https://${server_hostname:-localhost}:${gui_port}
    - Credentials: Check /opt/openvox-gui/config/.credentials

EOF
    fi
}

# =============================================================================
# SECTION: Installation Phases
# =============================================================================
# Each phase_* function orchestrates one logical step of the installation.
# These are called from main() and delegate to component-specific functions
# defined in the lib/*.sh scripts.

# Phase 1: Configure package repositories
phase_setup_repo() {
    log_info "Phase 1: Setting up package repositories..."
    setup_vox_repo
}

# Phase 2: Install selected components
phase_install_components() {
    log_info "Phase 2: Installing components..."

    [[ "$INSTALL_AGENT"    == "true" ]] && install_agent
    [[ "$INSTALL_SERVER"   == "true" ]] && install_server
    [[ "$INSTALL_SERVER"   == "true" ]] && install_puppetdb
    [[ "$INSTALL_R10K"     == "true" ]] && install_r10k
    [[ "$INSTALL_OPENBOLT" == "true" ]] && install_openbolt
    [[ "$INSTALL_GUI"      == "true" ]] && install_gui

    log_info "Component installation complete"
}

# Phase 3: Post-install configuration (firewall, SELinux, services, r10k deploy)
phase_post_install() {
    log_info "Phase 3: Post-install configuration..."

    configure_firewall
    configure_selinux
    configure_services

    # Deploy environments with r10k now that everything is installed
    if [[ "$INSTALL_R10K" == "true" ]]; then
        deploy_environments
        deploy_puppetfile_per_environment
    fi
    
    # Deploy control repository and configure Hiera
    if [[ "$INSTALL_SERVER" == "true" && -n "$r10k_remote" ]]; then
        deploy_control_repo
    fi
}

# Phase 4: Verify services and connectivity
phase_verify() {
    log_info "Phase 4: Verifying installation..."

    verify_services
    verify_connectivity

    if [[ "$INSTALL_OPENBOLT" == "true" ]]; then
        verify_openbolt
    fi
}

# Phase 5: Final agent run
phase_finalize() {
    log_info "Phase 5: Finalizing installation..."
    
    # Run puppet agent -t to complete configuration
    if [[ "${run_final_agent:-true}" != "false" ]]; then
        log_info "Running puppet agent -t to complete configuration..."
        
        if [[ "$DRY_RUN" != "true" ]]; then
            # Run agent, allow failures (may need cert signing)
            /opt/puppetlabs/bin/puppet agent --test --detailed-exitcodes 2>&1 || true
        else
            log_info "Dry-run: would run puppet agent --test"
        fi
        
        log_info "Initial agent run complete"
    else
        log_info "Skipping final agent run (run_final_agent=false)"
    fi
    
    log_info "OpenVox installation complete!"
    log_info "Run 'puppet agent -t' to apply configuration"
}

# =============================================================================
# SECTION: Main Execution
# =============================================================================

main() {
    # Step 1: Parse CLI arguments
    parse_args "$@"

    # Step 2: Display banner
    print_banner

    # Step 3: Check for root privileges
    check_privileges

    # Step 4: Set up file logging early so all messages are captured
    setup_logging

    # Step 5: Display startup information
    log_info "Starting OpenVox installation..."
    log_info "Config file: $CONFIG_FILE"

    # Step 6: Run preflight checks (OS, disk, network)
    if [[ "$SKIP_PREFLIGHT" != "true" ]]; then
        run_preflight
    else
        log_warn "Skipping preflight checks (--skip-preflight)"
    fi

    # Step 7: Load configuration from file (if it exists)
    load_config "$CONFIG_FILE"

    # Step 8: Determine which components to install
    set_install_mode

    # Step 9: Interactive prompts (skipped if --non-interactive)
    prompt_for_config

    # Step 10: Handle dry-run mode
    if [[ "$DRY_RUN" == "true" ]]; then
        log_warn "DRY RUN MODE — No changes will be made"
        dry_run
        print_summary
        exit 0
    fi

    # Step 11: Execute installation phases
    phase_setup_repo
    phase_install_components
    phase_post_install
    phase_verify
    phase_finalize

    # Step 12: Done
    log_info "Installation complete!"
    print_summary
}

# =============================================================================
# SECTION: Script Entry Point
# =============================================================================
# Execute main with all CLI arguments.
# set -e already handles error propagation — no need for && / || wrappers.

main "$@"
